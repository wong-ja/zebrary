# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Session secret for express-session
SESSION_SECRET=change-me-to-a-random-string

# Optional: Port for local development (defaults to 3000)
PORT=3000

# Optional: Open Library API base URL (defaults to https://openlibrary.org)
OPEN_LIBRARY_API_BASE=https://openlibrary.org

# Optional: Google Books API key (free tier, for secondary source)
GOOGLE_BOOKS_API_KEY=
