{
  "name": "book-tracker",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "start": "node src/index.js",
    "dev": "concurrently \"npm run watch:css\" \"node --watch src/index.js\"",
    "apply-schema": "node src/apply-schema.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "node-cron": "^4.4.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tailwindcss": "^3.4.19"
  }
}
